# ── Required (or set via sidebar in the UI) ──────────────
# Your Steam 64-bit ID (get it from steamid.io)
STEAM_ID=

# ── Optional ─────────────────────────────────────────────
# CSFloat API key (optional; adds CSFloat as a secondary price source)
CSFLOAT_API_KEY=

# Comma-separated market hash names to pre-populate the watchlist
WATCHLIST=

# ntfy.sh topic for push notifications (create at ntfy.sh)
NTFY_TOPIC=

# Alert when price changes by this fraction (0.05 = 5%)
ALERT_THRESHOLD=0.05

# ── Rate-limit safeguards (optional — sane defaults) ─────
# Seconds between each price API call (default 3.0)
# PRICE_DELAY_SEC=3.0

# Dashboard cache TTL in seconds (default 1200 = 20 min)
# CSFLOAT_CACHE_TTL_SEC=1200

# Max items to price per dashboard load / worker cycle (default 40)
# CSFLOAT_MAX_ITEMS=40

# Worker: seconds between full checks (default 3600 = 1 hour)
# WORKER_POLL_INTERVAL_SEC=3600

# Worker: back-off seconds after a 429 (default 600 = 10 min)
# CSFLOAT_RATE_LIMIT_BACKOFF_SEC=600
