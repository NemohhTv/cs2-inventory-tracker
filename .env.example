# Your Steam 64-bit ID (e.g. from steamid.io)
STEAM_ID=

# CSFloat API key (optional for public listings; get from csfloat.com)
CSFLOAT_API_KEY=

# Comma-separated market hash names of items to track (e.g. "AWP | Dragon Lore (Field-Tested),AK-47 | Redline (Field-Tested)")
WATCHLIST=

# ntfy.sh topic name for push notifications (create at ntfy.sh)
NTFY_TOPIC=

# Alert when price changes by this fraction (0.05 = 5%)
ALERT_THRESHOLD=0.05
